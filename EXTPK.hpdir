  ChooseMainMenu ½
    @ #NOTE Choose: ChooseMainMenu
    @ Displays a unified menu with all features provided by the Extension Pack
    @ HP, offering a convenient shortcut for quick access.

    "Extension Pack HP"
    {
      { "1.Solve nonlinear sys" ½ AppSolveNLSystem ╗ }
      { "2.Triangle solver" ½ AppSolveTriangle ╗ }
      { "3.Finance" ½ ChooseFinanceMenu ╗ }
      { "4.Time" ½ ChooseTimeMenu ╗ }
      { "5.Prob. distributions" ½ ChooseStatDist ╗ }
      { "6.Custom menus" ½ ChooseCustomMenus ╗ }
      { "7.System tools" ½ ChooseSystemTools ╗ }
    }
    UtilGuiChoose
  ╗

