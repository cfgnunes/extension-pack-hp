  @ ---------------------------------------------------------------------------
  @ #XXX Apps
  @ These functions are self-contained apps with graphical user interfaces.
  @ ---------------------------------------------------------------------------

  AppFinanceDepreciationDB ½
    @ #NOTE App: AppFinanceDepreciationDB

    "DECLINING BALANCE (DB)"
    {
      { "Cost:   " "Enter asset cost value" }
      { "Salvage:" "Enter asset salvage value" }
      { "Life:   " "Enter end of asset life" }
      { "Factor: " "Enter depreciation factor" }
    }
    { 1 0 }
    { }
    { 10000 1000 4 200 }
    UtilGuiInform

    Ź SBV SAL L DBF
    ½
      UtilPushSystemFlagsApp

      @ The columns of the output table are:
      @ - 1 Period number (j)
      @ - 2 Depreciation expense during period j ($DPN)
      @ - 3 Remaining depreciable value at end of period j ($RDV)
      'Å' 'ÅDepr.' 'ÅValue'
      0 0 SBV
      { 2 3 } ŹARRY

      SBV '$RDV' STO

      @ Calculates the declining balance rate.
      DBF 100 / L /

      Ź RATE
      ½
        1 L FOR j
          @ Calculate depreciation for the period.
          $RDV RATE * ŹNUM '$DPN' STO

          @ Ensure $RDV doesn't fall below SAL.
          $RDV $DPN - SAL < IF THEN
            $RDV SAL - ŹNUM '$DPN' STO
          END

          $RDV $DPN - ŹNUM '$RDV' STO

          @ Add the line to the output table.
          j $DPN 2 RND $RDV 2 RND { 1 3 } ŹARRY SWAP 1 ROW+

          @ If the $RDV is equal to SAL, stop the loop.
          $RDV SAL 0.001 + < IF THEN
            L 'j' STO @ Workaround to break the FOR loop.
          END
        NEXT
      ╗

      '$RDV' PURGE
      '$DPN' PURGE

      POP
    ╗
  ╗

  AppFinanceDepreciationSL ½
    @ #NOTE App: AppFinanceDepreciationSL

    "STRAIGHT LINE (SL)"
    {
      { "Cost:   " "Enter asset cost value" }
      { "Salvage:" "Enter asset salvage value" }
      { "Life:   " "Enter end of asset life" }
    }
    { 1 0 }
    { }
    { 10000 1000 4 }
    UtilGuiInform

    Ź SBV SAL L
    ½
      UtilPushSystemFlagsApp

      @ The columns of the output table are:
      @ - 1 Period number (j)
      @ - 2 Depreciation expense during period j ($DPN)
      @ - 3 Remaining depreciable value at end of period j ($RDV)

      'Å' 'ÅDepr.' 'ÅValue'
      0 0 SBV
      { 2 3 } ŹARRY

      SBV '$RDV' STO

      @ Calculates the constant $DPN.
      SBV SAL - L / ŹNUM

      Ź $DPN
      ½
        1 L FOR j
          @ Calculates the $RDV.
          $RDV $DPN - ŹNUM
          '$RDV' STO

          @ Add the line to the output table.
          j $DPN 2 RND $RDV 2 RND { 1 3 } ŹARRY SWAP 1 ROW+
        NEXT
      ╗

      '$RDV' PURGE

      POP
    ╗
  ╗

  AppFinanceDepreciationSOYD ½
    @ #NOTE App: AppFinanceDepreciationSOYD

    "SUM-OF-THE-YEARS DIGITS"
    {
      { "Cost:   " "Enter asset cost value" }
      { "Salvage:" "Enter asset salvage value" }
      { "Life:   " "Enter end of asset life" }
    }
    { 1 0 }
    { }
    { 10000 1000 4 }
    UtilGuiInform

    Ź SBV SAL L
    ½
      UtilPushSystemFlagsApp

      @ The columns of the output table are:
      @ - 1 Period number (j)
      @ - 2 Depreciation expense during period j ($DPN)
      @ - 3 Remaining depreciable value at end of period j ($RDV)

      'Å' 'ÅDepr.' 'ÅValue'
      0 0 SBV
      { 2 3 } ŹARRY

      SBV '$RDV' STO

      @ Calculates the sum-of-years digits.
      L FLOOR 1 + L FLOOR L FP 2 * + * 2 /

      @ Total depreciation.
      SBV SAL -

      Ź SOYD DEP
      ½
        1 L FOR j
          @ Depreciation for year j.
          L j - 1 + SOYD / DEP * ŹNUM

          @ Calculates the $RDV.
          DUP $RDV SWAP - ŹNUM '$RDV' STO

          @ Add the line to the output table.
          j SWAP  2 RND $RDV 2 RND { 1 3 } ŹARRY SWAP 1 ROW+
        NEXT
      ╗

      '$RDV' PURGE

      POP
    ╗
  ╗

  AppFinanceEqRate ½
    @ #NOTE App: AppFinanceEqRate

    "EQUIVALENT INTEREST RATE"
    {
    { "Interest (%):" "Enter interest rate (%)" }
    { "Period:      " "Enter the period" }
    { "New period:  " "Enter the new period" }
    }
    { 1 0 }
    { }
    'I%YR' VTYPE IF 0 == THEN I%YR ELSE 0 END
    1
    12
    3
    ŹLIST
    UtilGuiInform

    Ź r m q
    ½
      UtilPushSystemFlagsApp

      '((1+r/100)^(q/m)-1)*100' EVAL

      'I%YR' STO
      I%YR ŹNUM 'I%YR' ŹTAG

      POP
    ╗
  ╗

  AppFinanceIRR ½
    @ #NOTE App: AppFinanceIRR
    @ This function calculates the Internal Rate of Return (IRR) of a cash
    @ flow.

    @ INFORM Section (Begin) --------------------------------------------------
    @ INFORM 'Title'.
    "INTERNAL RATE OF RETURN (IRR)"
    @ INFORM 'Field definitions'.
    {
      { "CFL:" "Enter cash flow" 3 }
    }
    @ INFORM 'Format' (col, tabs).
    { 1 0 }
    @ INFORM 'Default values'.
    { }
    @ INFORM 'Initial values'.
    'CFL' VTYPE IF 29 == THEN CFL ELSE [ -20 10 15 ] END
    1
    ŹLIST
    @ INFORM Section (End) ----------------------------------------------------
    UtilGuiInform

    @ Store inputs in variables to allow re-use and editing by the user.
    DUP
    'CFL' STO

    @ Calculates the IRR.
    Ź CFL
    ½
      @ Purge '$IRR' in case it already exists, to allow symbolic computation.
      '$IRR' PURGE

      UtilPushSystemFlagsApp

      "'"
      @ Loop: for t = 1 to 'CFL.size'.
      1
      CFL SIZE OBJŹ DROP
      FOR t
        "+" + CFL t GET "/(1+$IRR)^(" + t + "-1)" + +
      NEXT
      "=0'" + STRŹ

      @ Solve the equation where NPV = 0.
      @ Initial guess is 0.5 (50%) for the root finder (numerical solver).
      '$IRR' .5 ROOT

      @ Convert the result to percentage.
      100 * ŹNUM
      'I%YR' STO
      I%YR "IRR" ŹTAG

      POP

      '$IRR' PURGE
    ╗
  ╗

  AppFinanceNFV ½
    @ #NOTE App: AppFinanceNFV
    @ This function calculates the Net Future Value (NFV) of a cash flow
    @ series.

    @ INFORM Section (Begin) --------------------------------------------------
    @ INFORM 'Title'.
    "NET FUTURE VALUE (NFV)"
    @ INFORM 'Field definitions'.
    {
      { "CFL:" "Enter cash flow" 3 }
      { "I%: " "Enter interest rate (%)" 0 }
    }
    @ INFORM 'Format' (col, tabs).
    { 1 0 }
    @ INFORM 'Default values'.
    { }
    @ INFORM 'Initial values'.
    'CFL' VTYPE IF 29 == THEN CFL ELSE [ -20 10 15 ] END
    'I%YR' VTYPE IF 0 == THEN I%YR ELSE 5 END
    2
    ŹLIST
    @ INFORM Section (End) ----------------------------------------------------
    UtilGuiInform

    @ Store inputs in variables to allow re-use and editing by the user.
    2 DUPN
    'I%YR' STO
    'CFL' STO

    @ Convert percentage rate to decimal
    100 /

    @ Calculates the NPV.
    Ź CFL r
    ½
      UtilPushSystemFlagsApp

      @ Initialize the accumulator in the stack.
      0

      @ Loop: for t = 1 to 'CFL.size'.
      1
      CFL SIZE OBJŹ DROP
      FOR t
        CFL t GET  @ Get value of CFL[t].
        1 r +      @ Calculates (1+r).
        t 1 - ^ /  @ Calculates CFL[t] / (1+r)^(t-1).
        +          @ Add to the accumulator.
      NEXT

      @ Calculates the NFV.
      1 r +
      CFL SIZE OBJŹ DROP 1 - ^ *

      ŹNUM

      'FV' STO
      FV "NFV" ŹTAG

      POP
    ╗
  ╗

  AppFinanceNPV ½
    @ #NOTE App: AppFinanceNPV
    @ This function calculates the Net Present Value (NPV) of a cash flow
    @ series.

    @ INFORM Section (Begin) --------------------------------------------------
    @ INFORM 'Title'.
    "NET PRESENT VALUE (NPV)"
    @ INFORM 'Field definitions'.
    {
      { "CFL:" "Enter cash flow" 3 }
      { "I%: " "Enter interest rate (%)" 0 }
    }
    @ INFORM 'Format' (col, tabs).
    { 1 0 }
    @ INFORM 'Default values'.
    { }
    @ INFORM 'Initial values'.
    'CFL' VTYPE IF 29 == THEN CFL ELSE [ -20 10 15 ] END
    'I%YR' VTYPE IF 0 == THEN I%YR ELSE 5 END
    2
    ŹLIST
    @ INFORM Section (End) ----------------------------------------------------
    UtilGuiInform

    @ Store inputs in variables to allow re-use and editing by the user.
    2 DUPN
    'I%YR' STO
    'CFL' STO

    @ Convert percentage rate to decimal
    100 /

    @ Calculates the NPV.
    Ź CFL r
    ½
      UtilPushSystemFlagsApp

      @ Initialize the accumulator in the stack.
      0

      @ Loop: for t = 1 to 'CFL.size'.
      1
      CFL SIZE OBJŹ DROP
      FOR t
        CFL t GET  @ Get value of CFL[t].
        1 r +      @ Calculates (1+r).
        t 1 - ^ /  @ Calculates CFL[t] / (1+r)^(t-1).
        +          @ Add to the accumulator.
      NEXT

      ŹNUM
      'PV' STO
      PV "NPV" ŹTAG

      POP
    ╗
  ╗

  AppFinanceNUS ½
    @ #NOTE App: AppFinanceNUS
    @ This function calculates the Net Uniform Series (NUS) of a cash flow
    @ series.

    @ INFORM Section (Begin) --------------------------------------------------
    @ INFORM 'Title'.
    "NET UNIFORM SERIES (NUS)"
    @ INFORM 'Field definitions'.
    {
      { "CFL:" "Enter cash flow" 3 }
      { "I%: " "Enter interest rate (%)" 0 }
    }
    @ INFORM 'Format' (col, tabs).
    { 1 0 }
    @ INFORM 'Default values'.
    { }
    @ INFORM 'Initial values'.
    'CFL' VTYPE IF 29 == THEN CFL ELSE [ -20 10 15 ] END
    'I%YR' VTYPE IF 0 == THEN I%YR ELSE 5 END
    2
    ŹLIST
    @ INFORM Section (End) ----------------------------------------------------
    UtilGuiInform

    @ Store inputs in variables to allow re-use and editing by the user.
    2 DUPN
    'I%YR' STO
    'CFL' STO

    @ Convert percentage rate to decimal
    100 /

    @ Calculates the NPV.
    Ź CFL r
    ½
      UtilPushSystemFlagsApp

      @ Initialize the accumulator in the stack.
      0

      @ Loop: for t = 1 to 'CFL.size'.
      1
      CFL SIZE OBJŹ DROP
      FOR t
        CFL t GET  @ Get value of CFL[t].
        1 r +      @ Calculates (1+r).
        t 1 - ^ /  @ Calculates CFL[t] / (1+r)^(t-1).
        +          @ Add to the accumulator.
      NEXT

      @ Calculates the NUS.
      r *
      1 1 r +
      0 CFL SIZE OBJŹ DROP 1 - - ^ - /

      ŹNUM
      'PMT' STO
      PMT "NUS" ŹTAG

      POP
    ╗
  ╗

