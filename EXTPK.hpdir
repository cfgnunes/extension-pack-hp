  AppStatDistContBeta ½
    @#NOTE App: AppStatDistContBeta

    "Beta X~B(ī,▀)"
    {
      { "ī:" "Parameter ī" }
      { "▀:" "Parameter ▀" }
      { "x:" "x value for P(Xēx) (left tail)" }
    }
    { 1 0 }
    { }
    { 2 2 .5 }
    UtilGuiInform

    Ź ī ▀ x
    ½
      UtilPushSystemFlagsApp

      'ä(0,x,a^(ī-1)*(1-a)^(▀-1)/(GAMMA(ī)*GAMMA(▀)/GAMMA(ī+▀)),a)' ŹNUM
      "P(Xē" x + ")" + ŹTAG

      POP
    ╗
  ╗

