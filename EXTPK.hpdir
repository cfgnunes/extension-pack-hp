      { "EDIT" ½ 35.1 KEYEVAL ╗ }
      { "VIEW" ½ DUP SCROLL ╗ }
      { "%T" ½ %T ŹNUM ╗ }
      { "%CH" ½ %CH ŹNUM ╗ }
      { "%" ½ % ŹNUM ╗ }
