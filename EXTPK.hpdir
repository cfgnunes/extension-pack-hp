      { "ab/c" ½ XFRAC ╗ }
      @ Options - Page 2.
      { }
      { }
      { }
      { }
      { }
      { "MENUå" ½ CMENU ╗ }
    }

    @ Define and display the Custom Menu.
    MENU
  ╗

