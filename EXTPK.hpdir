    { }
    { 5 .5 1 }
    UtilGuiInform

    Ź n p x
    ½
      UtilPushSystemFlagsApp

      @ Input validations.
      x n "x" "n" UtilValidateLessEqual

      'COMB(n,x)*p^x*(1.-p)^(n-x)' ŹNUM
      "P(x=" x ŹQ + ")" + ŹTAG

      @ Additionally calculate the CDF value.
      'ģ(j=0,x,COMB(n,j)*p^j*(1.-p)^(n-j))' ŹNUM
      "P(xē" x ŹQ + ")" + ŹTAG

      POP
